# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/savoria

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh

# ── Table QR codes (required for phone scanning) ──
# Phones cannot open http://localhost — use a URL the phone can reach:
#
# Same Wi‑Fi dev (find IP: ipconfig → IPv4):
# PUBLIC_APP_URL=http://192.168.1.10:3000
#
# Production (Vercel frontend example):
# PUBLIC_APP_URL=https://savoria-app-frontend-ekzd.vercel.app
#
# Quick tunnel test:
# PUBLIC_APP_URL=https://xxxx.ngrok-free.app
#
PUBLIC_APP_URL=http://localhost:3000

# Also accepted (same purpose): CLIENT_URL or FRONTEND_URL

PORT=5000
